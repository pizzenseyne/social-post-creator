# ─── Clé API Anthropic (Claude) — Génération de légendes ──────────────────────
# Obtenez votre clé sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── URL de base du serveur ────────────────────────────────────────────────────
# Pour Instagram : l'URL doit être accessible depuis internet (ex: via ngrok)
# Pour une utilisation locale uniquement : laissez http://localhost:8000
BASE_URL=http://localhost:8000

# ─── Génération IA de médias (OpenMontage) — optionnel ────────────────────────
# Active l'onglet "Générer avec IA" dans l'étape Média.
# Ajoutez au moins une clé pour activer la fonctionnalité.

# Image : OpenAI DALL-E 3 — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Image : Flux Pro via fal.ai — https://fal.ai/dashboard/keys
FAL_KEY=...

# Vidéo : Runway Gen-3 — https://dev.runwayml.com/
RUNWAY_API_KEY=...

# ─── Les clés des réseaux sociaux se configurent dans l'interface Paramètres ───
# (Instagram, Facebook, TikTok, Google My Business)
